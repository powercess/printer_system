# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=print_system
DB_USERNAME=root
DB_PASSWORD=your_password_here

# JWT/Sa-Token Configuration
SA-TOKEN-TOKEN-NAME=satoken
SA-TOKEN-SECRET-KEY=powercess-printer-system-secret-key-2024
SA-TOKEN-TIMEOUT=172800
SA-TOKEN-ACTIVE-TIMEOUT=-1

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=50MB
MAX_REQUEST_SIZE=100MB

# =============================================================================
# Storage Configuration (存储配置)
# =============================================================================
# 存储类型: local (本地存储) | s3 (对象存储)
STORAGE_TYPE=local

# S3 对象存储配置 (仅当 STORAGE_TYPE=s3 时需要)
# 支持兼容 S3 协议的服务: AWS S3, RustFS, MinIO, 阿里云OSS, 腾讯云COS, 华为云OBS
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_REGION=us-east-1
# S3_BUCKET=printer-files
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key
# S3_PATH_STYLE=false
# S3_PRESIGNED_EXPIRATION=3600

# RustFS 示例配置:
# S3_ENDPOINT=http://your-rustfs-host:9000
# S3_REGION=cn-east-1
# S3_BUCKET=printer-files
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key
# S3_PATH_STYLE=true

# MinIO 示例配置:
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_BUCKET=printer-files
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_PATH_STYLE=true

# 阿里云 OSS 示例配置:
# S3_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# S3_REGION=cn-hangzhou
# S3_BUCKET=printer-files
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key
# S3_PATH_STYLE=false

# 腾讯云 COS 示例配置:
# S3_ENDPOINT=https://cos.ap-guangzhou.myqcloud.com
# S3_REGION=ap-guangzhou
# S3_BUCKET=printer-files-1250000000
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key
# S3_PATH_STYLE=false

# =============================================================================
# CUPS Configuration (支持单服务器和多服务器)
# =============================================================================

# 单服务器配置（向后兼容）
CUPS_HOST=localhost
CUPS_PORT=631
CUPS_USERNAME=
CUPS_PASSWORD=
CUPS_SECURE=false

# 多服务器配置（可选）
# 格式: CUPS_SERVERS_0_<property>, CUPS_SERVERS_1_<property>, ...
# 示例:
# CUPS_SERVERS_0_ID=main-cups
# CUPS_SERVERS_0_HOST=192.168.1.100
# CUPS_SERVERS_0_PORT=631
# CUPS_SERVERS_0_USERNAME=admin
# CUPS_SERVERS_0_PASSWORD=secret
# CUPS_SERVERS_0_SECURE=true
# CUPS_SERVERS_0_PRIORITY=10
#
# CUPS_SERVERS_1_ID=backup-cups
# CUPS_SERVERS_1_HOST=192.168.1.101
# CUPS_SERVERS_1_PORT=631
# CUPS_SERVERS_1_PRIORITY=5

# 负载均衡策略: priority (按优先级) | round_robin (轮询) | random (随机)
CUPS_STRATEGY=priority

# 模拟模式 (用于测试，不连接真实CUPS)
CUPS_MOCK_MODE=false

# 连接超时 (毫秒)
CUPS_TIMEOUT=30000

# Payment Configuration (Qixiang Pay)
PAY_PID=your_pay_pid
PAY_KEY=your_pay_key
PAY_API_URL=https://api.payqixiang.cn/mapi.php
PAY_SUBMIT_URL=https://api.payqixiang.cn/submit.php
PAY_QUERY_URL=https://api.payqixiang.cn/api.php

# Base URL
BASE_URL=https://printer.powercess.com

# Spring Security Configuration
SECURITY_USER_NAME=admin
SECURITY_USER_PASSWORD=admin123

# =============================================================================
# Gotenberg Configuration (文件转PDF服务)
# =============================================================================
# Gotenberg 服务地址
GOTENBERG_URL=http://localhost:3000

# 转换超时时间（毫秒）
GOTENBERG_TIMEOUT=60000

# =============================================================================
# Logging Configuration (可选)
# =============================================================================
# 日志模式: dev (详细日志) | prod (生产日志) | quiet (静默模式)
LOG_MODE=prod

# 可以单独控制各个日志级别 (会覆盖 LOG_MODE 的设置):
# LOG_LEVEL_APP=INFO        # 应用日志级别
# LOG_LEVEL_WEB=INFO        # Web 请求日志级别
# LOG_LEVEL_DB=INFO         # 数据库日志级别

# MyBatis 日志实现:
# StdOutImpl (控制台输出，开发用) | NoLoggingImpl (无日志，生产用)
# MYBATIS_LOG_IMPL=org.apache.ibatis.logging.stdout.NoLoggingImpl