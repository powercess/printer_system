# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=print_system
DB_USERNAME=root
DB_PASSWORD=your_password_here

# JWT/Sa-Token Configuration
SA-TOKEN-TOKEN-NAME=satoken
SA-TOKEN-SECRET-KEY=powercess-printer-system-secret-key-2024
SA-TOKEN-TIMEOUT=172800
SA-TOKEN-ACTIVE-TIMEOUT=-1

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=50MB
MAX_REQUEST_SIZE=100MB

# CUPS Configuration
CUPS_HOST=localhost
CUPS_PORT=631
CUPS_USERNAME=
CUPS_PASSWORD=
CUPS_SECURE=false

# Payment Configuration (Qixiang Pay)
PAY_PID=your_pay_pid
PAY_KEY=your_pay_key
PAY_API_URL=https://api.payqixiang.cn/mapi.php
PAY_SUBMIT_URL=https://api.payqixiang.cn/submit.php
PAY_QUERY_URL=https://api.payqixiang.cn/api.php

# Base URL
BASE_URL=https://printer.powercess.com

# Spring Security Configuration
SECURITY_USER_NAME=admin
SECURITY_USER_PASSWORD=admin123

# =============================================================================
# Logging Configuration (可选)
# =============================================================================
# 日志模式: dev (详细日志) | prod (生产日志) | quiet (静默模式)
LOG_MODE=prod

# 可以单独控制各个日志级别 (会覆盖 LOG_MODE 的设置):
# LOG_LEVEL_APP=INFO        # 应用日志级别
# LOG_LEVEL_WEB=INFO        # Web 请求日志级别
# LOG_LEVEL_DB=INFO         # 数据库日志级别

# MyBatis 日志实现:
# StdOutImpl (控制台输出，开发用) | NoLoggingImpl (无日志，生产用)
# MYBATIS_LOG_IMPL=org.apache.ibatis.logging.stdout.NoLoggingImpl