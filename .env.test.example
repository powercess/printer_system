# =============================================================================
# 测试环境配置示例
# =============================================================================
# 使用方式: 复制此文件为 .env.test 并填入实际值
# cp .env.test.example .env.test
# =============================================================================

# =============================================================================
# CUPS 测试配置
# =============================================================================
CUPS_TEST_HOST=localhost
CUPS_TEST_PORT=631
CUPS_TEST_USERNAME=root
CUPS_TEST_PASSWORD=

# 可选：测试 PDF 文件路径
# CUPS_TEST_PDF=

# =============================================================================
# S3 存储测试配置
# =============================================================================
# 存储类型: local (本地存储) | s3 (对象存储)
STORAGE_TYPE=s3

# S3 对象存储配置
# 支持兼容 S3 协议的服务: AWS S3, RustFS, MinIO, 阿里云OSS, 腾讯云COS, 华为云OBS
S3_ENDPOINT=https://your-s3-endpoint.com
S3_REGION=us-east-1
S3_BUCKET=printer-files-test
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_PATH_STYLE=true
S3_PRESIGNED_EXPIRATION=3600

# RustFS 测试示例:
# S3_ENDPOINT=https://rustfs.example.com:9000
# S3_REGION=cn-east-1
# S3_BUCKET=printer-files-test
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key
# S3_PATH_STYLE=true

# MinIO 测试示例:
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_BUCKET=printer-files-test
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_PATH_STYLE=true

# 阿里云 OSS 测试示例:
# S3_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# S3_REGION=cn-hangzhou
# S3_BUCKET=printer-files-test
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key
# S3_PATH_STYLE=false

# 腾讯云 COS 测试示例:
# S3_ENDPOINT=https://cos.ap-guangzhou.myqcloud.com
# S3_REGION=ap-guangzhou
# S3_BUCKET=printer-files-test-1250000000
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key
# S3_PATH_STYLE=false

# =============================================================================
# Gotenberg 测试配置
# =============================================================================
GOTENBERG_URL=http://localhost:3000
GOTENBERG_TIMEOUT=60000